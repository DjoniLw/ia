# ──────────────────────────────────────────────────────────
# Aesthera API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# Em produção (Railway), configure via environment variables.
# ──────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Banco de dados ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aesthera

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Autenticação JWT ────────────────────────────────────────
# OBRIGATÓRIO em produção: mínimo 32 caracteres aleatórios
JWT_SECRET=substitua-por-segredo-de-pelo-menos-32-caracteres
# Nota: refresh tokens são opacos gerenciados via Redis (NÃO são JWT assinados).
# A verificação de refresh usa hash SHA-256 armazenado no Redis, não assinatura JWT.
# JWT_REFRESH_SECRET não existe neste projeto — não adicione essa variável.
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
# Em produção, defina o(s) domínio(s) permitidos (sem wildcard).
# Múltiplos: separe por vírgula — ex: https://app.aesthera.com.br,https://admin.aesthera.com.br
# ⚠️  CORS_ORIGIN='*' bloqueia o boot em produção (AMBIENTE_DEV não definido).
CORS_ORIGIN=http://localhost:3001

# ── Frontend URL (links em e-mails) ────────────────────────
FRONTEND_URL=http://localhost:3001

# ── Stripe ──────────────────────────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Obtenha em: https://dashboard.stripe.com/webhooks
# ⚠️  OBRIGATÓRIO para que webhooks Stripe sejam validados e processados.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudflare R2 (uploads de arquivos) ────────────────────────────
# Obtém em: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# ⚠️  JAMAIS commitar valores reais.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── MercadoPago ─────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-...
# Configurado no painel de webhooks do MercadoPago.
# ⚠️  OBRIGATÓRIO para que webhooks MercadoPago sejam validados e processados.
MP_WEBHOOK_SECRET=...

# ── E-mail (Resend) ─────────────────────────────────────────
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@aesthera.com.br

# ── WhatsApp (Z-API) ────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── IA (Google Gemini) ──────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Ambiente de desenvolvimento no Railway ──────────────────
# Defina AMBIENTE_DEV=S para indicar que é ambiente de homologação/dev no Railway.
# Quando ausente ou diferente de 'S', o sistema opera como produção.
# AMBIENTE_DEV=S
