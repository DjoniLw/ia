// Aesthera — Prisma Schema (completo)
// Todas as tabelas definidas antes de qualquer código de módulo.
// Convenções:
//   - clinic_id em todas as tabelas (tenant isolation)
//   - Amounts em BRL cents (Int)
//   - Time fields como String "HH:MM" (Prisma não tem tipo Time nativo sem @db.Time)
//   - Soft-delete via deleted_at (nunca DELETE físico em dados de negócio)
//   - LedgerEntry é append-only — nunca updated_at, nunca delete

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ClinicStatus {
  active
  suspended
  cancelled
}

enum ClinicPlan {
  trial
  starter
  pro
  enterprise
}

enum UserRole {
  admin
  staff
}

enum TransferStatus {
  pending
  confirmed
  rejected
  expired
}

enum TransferKind {
  clinic_registration
  user_invite
}

enum ContractStatus {
  pending
  signed
}

enum AppointmentStatus {
  draft
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum BillingStatus {
  pending
  paid
  overdue
  cancelled
}

enum PaymentGateway {
  stripe
  mercadopago
}

enum PaymentMethod {
  pix
  boleto
  card
}

enum PaymentStatus {
  pending
  paid
  failed
  expired
  refunded
  disputed
}

enum LedgerEntryType {
  credit
  debit
}

enum WalletEntryType {
  VOUCHER
  CREDIT
  CASHBACK
  PACKAGE
}

enum AccountsPayableStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum WalletEntryStatus {
  ACTIVE
  USED
  EXPIRED
}

enum WalletOriginType {
  OVERPAYMENT
  GIFT
  REFUND
  CASHBACK_PROMOTION
  PACKAGE_PURCHASE
  VOUCHER_SPLIT
}

enum WalletTransactionType {
  CREATE
  USE
  SPLIT
  ADJUST
}

enum NotificationType {
  whatsapp
  email
}

enum FileCategory {
  BEFORE_PHOTO
  AFTER_PHOTO
  MEASUREMENT
  EXAM
  OTHER
}

enum FileUploadStatus {
  PENDING
  CONFIRMED
}

enum NotificationStatus {
  pending
  sent
  failed
}

enum MeasurementSheetType {
  SIMPLE
  TABULAR
}

enum MeasurementInputType {
  INPUT
  CHECK
}

enum RecurrenceType {
  none
  daily
  weekly
}

enum PromotionDiscountType {
  PERCENTAGE
  FIXED
}

enum PromotionStatus {
  active
  inactive
  expired
}

// ─── Clinic ───────────────────────────────────────────────────────────────────
// Central tenant entity. Every other table references clinic_id.

model Clinic {
  id            String       @id @default(uuid())
  slug          String       @unique              // URL identifier: slug.aesthera.com.br
  name          String
  email         String
  document      String?      @unique              // CNPJ (único por empresa)
  phone         String?
  plan          ClinicPlan   @default(trial)
  status        ClinicStatus @default(active)
  emailVerified Boolean      @default(false)      @map("email_verified")
  emailVerificationToken    String?   @unique @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  timezone      String       @default("America/Sao_Paulo")
  address       Json?
  settings      Json?                             // notification prefs, due_date offset, etc.
  deletedAt     DateTime?                         @map("deleted_at")
  createdAt     DateTime     @default(now())      @map("created_at")
  updatedAt     DateTime     @updatedAt           @map("updated_at")

  auth             ClinicAuth?
  apiKeys          ApiKey[]
  businessHours    BusinessHour[]
  paymentMethodConfig PaymentMethodConfig?
  users            User[]
  sourceTransfers  TransferToken[] @relation("TransferSourceClinic")
  targetTransfers  TransferToken[] @relation("TransferTargetClinic")
  professionals    Professional[]
  services         Service[]
  customers        Customer[]
  appointments     Appointment[]
  blockedSlots     BlockedSlot[]
  billing          Billing[]
  payments         Payment[]
  ledgerEntries    LedgerEntry[]
  notificationLogs NotificationLog[]
  products         Product[]
  productSales     ProductSale[]
  clinicalRecords  ClinicalRecord[]
  equipment        Equipment[]
  rooms            Room[]
  supplies         Supply[]
  supplyPurchases  SupplyPurchase[]
  walletEntries    WalletEntry[]
  promotions       Promotion[]
  servicePackages  ServicePackage[]
  customerPackages CustomerPackage[]
  auditLogs        AuditLog[]
  accountsPayable  AccountsPayable[]
  manualReceipts   ManualReceipt[]
  customerFiles    CustomerFile[]
  bodyMeasurementFields  BodyMeasurementField[]
  bodyMeasurementRecords BodyMeasurementRecord[]
  measurementSheets    MeasurementSheet[]
  measurementSessions  MeasurementSession[]
  contractTemplates    ContractTemplate[]
  customerContracts    CustomerContract[]

  @@map("clinics")
}

// ─── Clinic Auth ──────────────────────────────────────────────────────────────

model ClinicAuth {
  id             String    @id @default(uuid())
  clinicId       String    @unique              @map("clinic_id")
  passwordHash   String                          @map("password_hash")
  failedAttempts Int       @default(0)           @map("failed_attempts")
  lockedUntil    DateTime?                        @map("locked_until")
  updatedAt      DateTime  @updatedAt             @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_auth")
}

// ─── Business Hours ───────────────────────────────────────────────────────────

model BusinessHour {
  id        String  @id @default(uuid())
  clinicId  String                       @map("clinic_id")
  dayOfWeek Int                          @map("day_of_week") // 0=Sun … 6=Sat
  openTime  String                       @map("open_time")   // HH:MM
  closeTime String                       @map("close_time")  // HH:MM
  isOpen    Boolean @default(true)       @map("is_open")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, dayOfWeek])
  @@map("business_hours")
}

model PaymentMethodConfig {
  id                       String   @id @default(uuid())
  clinicId                 String   @unique               @map("clinic_id")
  pixEnabled               Boolean  @default(true)        @map("pix_enabled")
  boletoEnabled            Boolean  @default(true)        @map("boleto_enabled")
  cardEnabled              Boolean  @default(true)        @map("card_enabled")
  installmentsEnabled      Boolean  @default(false)       @map("installments_enabled")
  installmentsMaxMonths    Int      @default(12)          @map("installments_max_months")
  installmentsMinAmount    Int      @default(10000)       @map("installments_min_amount")
  duplicataEnabled         Boolean  @default(false)       @map("duplicata_enabled")
  duplicataDaysInterval    Int      @default(30)          @map("duplicata_days_interval")
  duplicataMaxInstallments Int      @default(6)           @map("duplicata_max_installments")
  createdAt                DateTime @default(now())       @map("created_at")
  updatedAt                DateTime @updatedAt            @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("payment_method_configs")
}

// ─── API Key ─────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  clinicId   String                        @map("clinic_id")
  name       String?
  keyHash    String                        @map("key_hash")
  keyPrefix  String                        @map("key_prefix") // first 8 chars shown in UI
  expiresAt  DateTime?                     @map("expires_at")
  lastUsedAt DateTime?                     @map("last_used_at")
  createdAt  DateTime  @default(now())     @map("created_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("api_keys")
}

// ─── User (clinic staff) ─────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  clinicId        String                          @map("clinic_id")
  name            String
  email           String
  passwordHash    String?                         @map("password_hash") // null until invite accepted
  role            UserRole  @default(staff)
  active          Boolean   @default(true)
  screenPermissions String[] @default([])         @map("screen_permissions")
  inviteToken     String?   @unique               @map("invite_token")
  inviteExpiresAt DateTime?                       @map("invite_expires_at")
  lastLoginAt     DateTime?                       @map("last_login_at")
  createdAt       DateTime  @default(now())       @map("created_at")
  updatedAt       DateTime  @updatedAt            @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  sourceTransfers TransferToken[] @relation("TransferSourceUser")
  targetTransfers TransferToken[] @relation("TransferTargetUser")
  measurementSessions MeasurementSession[]

  @@unique([clinicId, email])
  @@index([clinicId])
  @@map("users")
}

model TransferToken {
  id            String         @id @default(uuid())
  token         String         @unique
  email         String
  sourceClinicId String?       @map("source_clinic_id")
  sourceUserId  String?        @map("source_user_id")
  targetClinicId String        @map("target_clinic_id")
  targetUserId  String?        @map("target_user_id")
  role          UserRole
  kind          TransferKind
  expiresAt     DateTime       @map("expires_at")
  status        TransferStatus @default(pending)
  createdAt     DateTime       @default(now()) @map("created_at")

  sourceClinic Clinic? @relation("TransferSourceClinic", fields: [sourceClinicId], references: [id], onDelete: SetNull)
  sourceUser   User?   @relation("TransferSourceUser", fields: [sourceUserId], references: [id], onDelete: SetNull)
  targetClinic Clinic  @relation("TransferTargetClinic", fields: [targetClinicId], references: [id], onDelete: Cascade)
  targetUser   User?   @relation("TransferTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@index([targetClinicId])
  @@index([targetUserId])
  @@map("transfer_tokens")
}

// ─── Professional ─────────────────────────────────────────────────────────────

model Professional {
  id          String    @id @default(uuid())
  clinicId    String                         @map("clinic_id")
  name        String
  email       String
  phone       String?
  speciality  String?
  address     Json?
  avatarUrl   String?                        @map("avatar_url")
  active      Boolean   @default(true)
  allServices Boolean   @default(false)      @map("all_services") // when true, professional performs all services (including future ones)
  deletedAt   DateTime?                      @map("deleted_at")
  createdAt   DateTime  @default(now())      @map("created_at")
  updatedAt   DateTime  @updatedAt           @map("updated_at")

  clinic       Clinic                    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  auth         ProfessionalAuth?
  workingHours    ProfessionalWorkingHour[]
  services        ProfessionalService[]
  appointments    Appointment[]
  blockedSlots    BlockedSlot[]
  clinicalRecords ClinicalRecord[]

  @@unique([clinicId, email])
  @@index([clinicId])
  @@map("professionals")
}

// ─── Professional Auth ────────────────────────────────────────────────────────

model ProfessionalAuth {
  id             String    @id @default(uuid())
  professionalId String    @unique              @map("professional_id")
  clinicId       String                          @map("clinic_id")
  passwordHash   String                          @map("password_hash")
  failedAttempts Int       @default(0)           @map("failed_attempts")
  lockedUntil    DateTime?                        @map("locked_until")
  updatedAt      DateTime  @updatedAt             @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("professional_auth")
}

// ─── Professional Working Hours ───────────────────────────────────────────────

model ProfessionalWorkingHour {
  id             String  @id @default(uuid())
  professionalId String                           @map("professional_id")
  clinicId       String                           @map("clinic_id")
  dayOfWeek      Int                              @map("day_of_week") // 0=Sun … 6=Sat
  startTime      String                           @map("start_time")  // HH:MM
  endTime        String                           @map("end_time")    // HH:MM
  isAvailable    Boolean @default(true)           @map("is_available")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@index([clinicId])
  @@map("professional_working_hours")
}

// ─── Professional ↔ Service (many-to-many) ────────────────────────────────────

model ProfessionalService {
  professionalId String @map("professional_id")
  serviceId      String @map("service_id")
  clinicId       String @map("clinic_id")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@index([clinicId])
  @@map("professional_services")
}

// ─── Service ─────────────────────────────────────────────────────────────────

model Service {
  id              String    @id @default(uuid())
  clinicId        String                         @map("clinic_id")
  name            String
  description     String?
  category        String?
  durationMinutes Int                            @map("duration_minutes") // must be multiple of 15
  price           Int                            // BRL cents
  active          Boolean   @default(true)
  deletedAt       DateTime?                      @map("deleted_at")
  createdAt       DateTime  @default(now())      @map("created_at")
  updatedAt       DateTime  @updatedAt           @map("updated_at")

  clinic        Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  professionals ProfessionalService[]
  appointments  Appointment[]
  supplies      ServiceSupply[]
  appointmentItems AppointmentServiceItem[]
  packageItems     ServicePackageItem[]

  @@index([clinicId])
  @@map("services")
}

// ─── Customer ─────────────────────────────────────────────────────────────────

model Customer {
  id         String    @id @default(uuid())
  clinicId   String                         @map("clinic_id")
  externalId String?                        @map("external_id")
  name       String
  email      String?
  phone      String?                        // E.164 for WhatsApp
  document   String?                        // CPF
  birthDate  DateTime? @db.Date             @map("birth_date")
  address    Json?
  notes      String?
  metadata   Json?
  active     Boolean   @default(true)
  bodyDataConsentAt DateTime?                      @map("body_data_consent_at") // LGPD Art. 11I — consentimento para dados corporais sensíveis
  deletedAt  DateTime?                      @map("deleted_at")
  createdAt  DateTime  @default(now())      @map("created_at")
  updatedAt  DateTime  @updatedAt           @map("updated_at")

  clinic               Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointments         Appointment[]
  billing              Billing[]
  payments             Payment[]
  ledgerEntries        LedgerEntry[]
  notificationLogs     NotificationLog[]
  productSales         ProductSale[]
  clinicalRecords      ClinicalRecord[]
  walletEntries        WalletEntry[]
  customerPackages     CustomerPackage[]
  customerFiles        CustomerFile[]
  bodyMeasurementRecords BodyMeasurementRecord[]
  measurementSessions  MeasurementSession[]
  customerContracts    CustomerContract[]

  @@unique([clinicId, email])
  @@unique([clinicId, document])
  @@unique([clinicId, externalId])
  @@index([clinicId])
  @@map("customers")
}

// ─── Blocked Slot ─────────────────────────────────────────────────────────────

model BlockedSlot {
  id             String         @id @default(uuid())
  clinicId       String                              @map("clinic_id")
  professionalId String                              @map("professional_id")
  reason         String?
  date           DateTime?      @db.Date             // null if recurring
  startTime      String                              @map("start_time") // HH:MM
  endTime        String                              @map("end_time")   // HH:MM
  recurrence     RecurrenceType @default(none)
  dayOfWeek      Int?                                @map("day_of_week") // 0–6, used when recurrence=weekly
  createdAt      DateTime       @default(now())      @map("created_at")

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([professionalId])
  @@map("blocked_slots")
}

// ─── Appointment ─────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(uuid())
  clinicId           String                               @map("clinic_id")
  customerId         String                               @map("customer_id")
  professionalId     String                               @map("professional_id")
  serviceId          String?                              @map("service_id")
  roomId             String?                              @map("room_id")
  status             AppointmentStatus @default(draft)
  scheduledAt        DateTime                             @map("scheduled_at")      // start date+time
  durationMinutes    Int                                  @map("duration_minutes")  // copied from service at booking
  price              Int                                  // BRL cents, copied from service (can be overridden)
  notes              String?
  cancellationReason String?                              @map("cancellation_reason")
  completedAt        DateTime?                            @map("completed_at")
  cancelledAt        DateTime?                            @map("cancelled_at")
  reminderJobId      String?                              @map("reminder_job_id")   // BullMQ job ID for D-1 cancel
  createdAt          DateTime          @default(now())    @map("created_at")
  updatedAt          DateTime          @updatedAt         @map("updated_at")

  clinic           Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  professional     Professional      @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service          Service?          @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  room             Room?             @relation(fields: [roomId], references: [id], onDelete: Restrict)
  billing          Billing?
  ledgerEntries    LedgerEntry[]
  notificationLogs NotificationLog[]
  equipment        AppointmentEquipment[]
  serviceItems     AppointmentServiceItem[]

  @@index([clinicId])
  @@index([clinicId, professionalId])
  @@index([clinicId, customerId])
  @@index([clinicId, scheduledAt])
  @@map("appointments")
}

// ─── Billing ─────────────────────────────────────────────────────────────────
// Auto-created by appointment.completed event — never created manually.

model Billing {
  id             String        @id @default(uuid())
  clinicId       String                             @map("clinic_id")
  customerId     String                             @map("customer_id")
  appointmentId  String        @unique              @map("appointment_id") // 1:1 with Appointment
  amount         Int                                // BRL cents
  status         BillingStatus @default(pending)
  paymentMethods String[]                           @map("payment_methods") // ['pix','boleto','card','installments','duplicata']
  paymentLink    String?                            @map("payment_link")
  paymentToken   String        @unique              @map("payment_token")   // public payment page token
  dueDate        DateTime      @db.Date             @map("due_date")
  paidAt         DateTime?                          @map("paid_at")
  overdueAt      DateTime?                          @map("overdue_at")
  cancelledAt    DateTime?                          @map("cancelled_at")
  createdAt      DateTime      @default(now())      @map("created_at")
  updatedAt      DateTime      @updatedAt           @map("updated_at")

  clinic           Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer         Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  appointment      Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  payments         Payment[]
  ledgerEntries    LedgerEntry[]     // credit on paid, debit on refund
  notificationLogs NotificationLog[]

  @@index([clinicId])
  @@index([clinicId, customerId])
  @@index([clinicId, status])
  @@map("billing")
}

// ─── Payment ─────────────────────────────────────────────────────────────────

model Payment {
  id               String         @id @default(uuid())
  clinicId         String                              @map("clinic_id")
  billingId        String                              @map("billing_id")
  customerId       String                              @map("customer_id")
  gateway          PaymentGateway
  method           PaymentMethod
  status           PaymentStatus  @default(pending)
  amount           Int                                 // BRL cents
  gatewayPaymentId String?        @unique              @map("gateway_payment_id")
  gatewayEventId   String?                             @map("gateway_event_id")  // idempotency key on webhooks
  paymentUrl       String?                             @map("payment_url")       // PIX QR code URL or boleto URL
  pixQrCode        String?                             @map("pix_qr_code")       // raw PIX copy-paste string
  paidAt           DateTime?                           @map("paid_at")
  expiresAt        DateTime?                           @map("expires_at")
  metadata         Json?
  createdAt        DateTime       @default(now())      @map("created_at")
  updatedAt        DateTime       @updatedAt           @map("updated_at")

  clinic        Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  billing       Billing       @relation(fields: [billingId], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ledgerEntries LedgerEntry[]

  @@index([clinicId])
  @@index([billingId])
  @@map("payments")
}

// ─── Ledger Entry ─────────────────────────────────────────────────────────────
// Append-only financial record — no updatedAt, never modified after creation.

model LedgerEntry {
  id            String          @id @default(uuid())
  clinicId      String                               @map("clinic_id")
  type          LedgerEntryType
  amount        Int                                  // BRL cents, always positive
  currency      String          @default("BRL")
  paymentId     String?                              @map("payment_id")   // FK → Payment (null for manual entries)
  billingId     String?                              @map("billing_id")
  appointmentId String?                              @map("appointment_id")
  customerId    String?                              @map("customer_id")
  description   String?
  metadata      Json?
  createdAt     DateTime        @default(now())      @map("created_at")   // immutable

  clinic      Clinic       @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  payment     Payment?     @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  billing     Billing?     @relation(fields: [billingId], references: [id], onDelete: Restrict)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([clinicId, createdAt])
  @@index([clinicId, appointmentId])
  @@index([clinicId, customerId])
  @@index([paymentId])
  @@map("ledger_entries")
}

// ─── Notification Log ─────────────────────────────────────────────────────────

model NotificationLog {
  id            String             @id @default(uuid())
  clinicId      String                                  @map("clinic_id")
  type          NotificationType
  channel       String                                  // phone number or email address
  event         String                                  // e.g. 'appointment.confirmed'
  appointmentId String?                                 @map("appointment_id")
  billingId     String?                                 @map("billing_id")
  customerId    String?                                 @map("customer_id")
  status        NotificationStatus @default(pending)
  attempts      Int                @default(0)
  lastAttemptAt DateTime?                               @map("last_attempt_at")
  error         String?
  payload       Json                                    // what was sent
  createdAt     DateTime           @default(now())      @map("created_at")

  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointment Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  billing     Billing?      @relation(fields: [billingId], references: [id], onDelete: SetNull)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([clinicId, status])
  @@map("notification_logs")
}

// ─── Product ──────────────────────────────────────────────────────────────────
// Product catalog for clinic retail/sales.

model Product {
  id          String    @id @default(uuid())
  clinicId    String                           @map("clinic_id")
  name        String
  description String?
  category    String?
  brand       String?
  sku         String?
  barcode     String?
  price       Int                              // selling price in BRL cents
  costPrice   Int?                             @map("cost_price")
  stock       Int       @default(0)
  minStock    Int       @default(0)            @map("min_stock")
  unit        String    @default("un")
  active      Boolean   @default(true)
  imageUrl    String?                          @map("image_url")
  ncm         String?                          // Nomenclatura Comum do Mercosul (fiscal)
  cest        String?                          // Código Especificador da Substituição Tributária
  cfop        String?                          // Código Fiscal de Operações e Prestações
  deletedAt   DateTime?                        @map("deleted_at")
  createdAt   DateTime  @default(now())        @map("created_at")
  updatedAt   DateTime  @updatedAt             @map("updated_at")

  clinic Clinic        @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  sales  ProductSale[]

  @@index([clinicId])
  @@map("products")
}

// ─── Product Sale ─────────────────────────────────────────────────────────────

model ProductSale {
  id         String    @id @default(uuid())
  clinicId   String                           @map("clinic_id")
  productId  String                           @map("product_id")
  customerId String?                          @map("customer_id")
  quantity   Int
  unitPrice  Int                              @map("unit_price")
  totalPrice Int                              @map("total_price")
  discount      Int       @default(0)
  paymentMethod String?                          @map("payment_method") // cash, pix, card, transfer
  notes         String?
  soldAt        DateTime  @default(now())        @map("sold_at")
  createdAt  DateTime  @default(now())        @map("created_at")

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([clinicId, productId])
  @@map("product_sales")
}

// ─── Clinical Record ──────────────────────────────────────────────────────────

model ClinicalRecord {
  id             String    @id @default(uuid())
  clinicId       String                           @map("clinic_id")
  customerId     String                           @map("customer_id")
  professionalId String?                          @map("professional_id")
  title          String
  content        String                           // clinical notes
  type           String    @default("note")       // note | exam | procedure | prescription | anamnesis
  performedAt    DateTime?                        @map("performed_at") // date the exam/procedure was actually performed
  createdAt      DateTime  @default(now())        @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([clinicId, customerId])
  @@map("clinical_records")
}

// ─── Supply (Insumos) ─────────────────────────────────────────────────────────
// Supplies are consumables used in services. They can also be sold as products.

model Supply {
  id          String    @id @default(uuid())
  clinicId    String                           @map("clinic_id")
  name        String
  description String?
  unit        String    @default("un")         // un, ml, g, kg, …
  costPrice   Int?                             @map("cost_price")  // BRL cents
  stock       Int       @default(0)
  minStock    Int       @default(0)            @map("min_stock")
  active      Boolean   @default(true)
  deletedAt   DateTime?                        @map("deleted_at")
  createdAt   DateTime  @default(now())        @map("created_at")
  updatedAt   DateTime  @updatedAt             @map("updated_at")

  clinic   Clinic          @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  services ServiceSupply[]
  purchases SupplyPurchase[]

  @@index([clinicId])
  @@map("supplies")
}

// ─── Service ↔ Supply (many-to-many) ─────────────────────────────────────────

model ServiceSupply {
  serviceId        String  @map("service_id")
  supplyId         String  @map("supply_id")
  clinicId         String  @map("clinic_id")
  quantity         Float   @default(1)         // quantity of usageUnit used per service execution
  usageUnit        String? @map("usage_unit")  // unit used in service (if different from supply.unit)
  conversionFactor Float   @default(1)         @map("conversion_factor") // how many usageUnit = 1 supply.unit

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  supply  Supply  @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@id([serviceId, supplyId])
  @@index([clinicId])
  @@map("service_supplies")
}

model SupplyPurchase {
  id               String   @id @default(uuid())
  clinicId         String                         @map("clinic_id")
  supplyId         String                         @map("supply_id")
  supplierName     String?                        @map("supplier_name")
  purchaseUnit     String                         @map("purchase_unit")
  purchaseQty      Float                          @map("purchase_qty")
  conversionFactor Float                          @map("conversion_factor")
  stockIncrement   Int                            @map("stock_increment")
  unitCost         Int                            @map("unit_cost")
  totalCost        Int                            @map("total_cost")
  notes            String?
  purchasedAt      DateTime                       @map("purchased_at")
  createdAt        DateTime @default(now())      @map("created_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  supply Supply @relation(fields: [supplyId], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([supplyId])
  @@map("supply_purchases")
}

// ─── Equipment ────────────────────────────────────────────────────────────────

model Equipment {
  id          String   @id @default(uuid())
  clinicId    String                        @map("clinic_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())      @map("created_at")
  updatedAt   DateTime @updatedAt           @map("updated_at")

  clinic       Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointments AppointmentEquipment[]

  @@index([clinicId])
  @@map("equipment")
}

model AppointmentEquipment {
  appointmentId String @map("appointment_id")
  equipmentId   String @map("equipment_id")

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  equipment   Equipment   @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([appointmentId, equipmentId])
  @@map("appointment_equipment")
}

// ─── Room ─────────────────────────────────────────────────────────────────────

model Room {
  id          String   @id @default(uuid())
  clinicId    String                        @map("clinic_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())      @map("created_at")
  updatedAt   DateTime @updatedAt           @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([clinicId])
  @@map("rooms")
}

// ─── Wallet Entry ─────────────────────────────────────────────────────────────
// Stores any type of customer balance: voucher, credit, cashback or package.

model WalletEntry {
  id               String            @id @default(uuid())
  clinicId         String                                  @map("clinic_id")
  customerId       String                                  @map("customer_id")
  type             WalletEntryType
  originalValue    Int                                     @map("original_value")  // BRL cents
  balance          Int                                     // BRL cents (current)
  code             String            @unique               // readable code e.g. VCHR-XXXX
  originType       WalletOriginType                        @map("origin_type")
  originReference  String?                                 @map("origin_reference") // e.g. billing ID
  notes            String?
  expirationDate   DateTime?         @db.Date              @map("expiration_date")
  status           WalletEntryStatus @default(ACTIVE)
  createdAt        DateTime          @default(now())       @map("created_at")
  updatedAt        DateTime          @updatedAt            @map("updated_at")

  clinic              Clinic              @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer            Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  transactions        WalletTransaction[]
  manualReceiptLines  ManualReceiptLine[]

  @@index([clinicId])
  @@index([clinicId, customerId])
  @@index([clinicId, status])
  @@index([clinicId, createdAt])
  @@map("wallet_entries")
}

// ─── Wallet Transaction ───────────────────────────────────────────────────────
// Append-only audit log of all operations performed on a wallet entry.

model WalletTransaction {
  id            String                @id @default(uuid())
  clinicId      String                                      @map("clinic_id")
  walletEntryId String                                      @map("wallet_entry_id")
  type          WalletTransactionType
  value         Int                                         // BRL cents
  reference     String?                                     // billing ID, voucher ID, etc.
  description   String?
  createdAt     DateTime              @default(now())       @map("created_at")

  walletEntry WalletEntry @relation(fields: [walletEntryId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([walletEntryId])
  @@map("wallet_transactions")
}

// ─── Appointment Service Item ─────────────────────────────────────────────────
// Supports multiple services per appointment (many-to-many).

model AppointmentServiceItem {
  id              String @id @default(uuid())
  appointmentId   String @map("appointment_id")
  serviceId       String @map("service_id")
  clinicId        String @map("clinic_id")
  price           Int    // price at time of booking
  durationMinutes Int    @map("duration_minutes")
  order           Int    @default(0)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([appointmentId, serviceId])
  @@index([clinicId])
  @@map("appointment_service_items")
}

// ─── Promotion ────────────────────────────────────────────────────────────────

model Promotion {
  id                   String               @id @default(uuid())
  clinicId             String               @map("clinic_id")
  name                 String
  code                 String
  description          String?
  discountType         PromotionDiscountType @map("discount_type")
  discountValue        Int                  @map("discount_value") // percentage (0-100) or BRL cents
  maxUses              Int?                 @map("max_uses")
  usesCount            Int                  @default(0) @map("uses_count")
  minAmount            Int?                 @map("min_amount")
  applicableServiceIds String[]             @map("applicable_service_ids")
  validFrom            DateTime             @map("valid_from")
  validUntil           DateTime?            @map("valid_until")
  status               PromotionStatus      @default(active)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  clinic Clinic           @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  usages PromotionUsage[]

  @@unique([clinicId, code])
  @@index([clinicId])
  @@map("promotions")
}

model PromotionUsage {
  id             String   @id @default(uuid())
  clinicId       String   @map("clinic_id")
  promotionId    String   @map("promotion_id")
  customerId     String   @map("customer_id")
  billingId      String?  @map("billing_id")
  discountAmount Int      @map("discount_amount")
  usedAt         DateTime @default(now()) @map("used_at")

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([promotionId])
  @@map("promotion_usages")
}

// ─── Service Package ─────────────────────────────────────────────────────────

model ServicePackage {
  id           String    @id @default(uuid())
  clinicId     String    @map("clinic_id")
  name         String
  description  String?
  price        Int       // BRL cents
  validityDays Int?      @map("validity_days")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  clinic           Clinic               @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  items            ServicePackageItem[]
  customerPackages CustomerPackage[]

  @@index([clinicId])
  @@map("service_packages")
}

model ServicePackageItem {
  id        String @id @default(uuid())
  packageId String @map("package_id")
  serviceId String @map("service_id")
  clinicId  String @map("clinic_id")
  quantity  Int    @default(1)

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([packageId, serviceId])
  @@index([clinicId])
  @@map("service_package_items")
}

model CustomerPackage {
  id            String    @id @default(uuid())
  clinicId      String    @map("clinic_id")
  customerId    String    @map("customer_id")
  packageId     String    @map("package_id")
  walletEntryId String?   @unique @map("wallet_entry_id")
  purchasedAt   DateTime  @default(now()) @map("purchased_at")
  expiresAt     DateTime? @map("expires_at")

  clinic    Clinic         @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer  Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  sessions  CustomerPackageSession[]

  @@index([clinicId])
  @@index([clinicId, customerId])
  @@map("customer_packages")
}

model CustomerPackageSession {
  id                String    @id @default(uuid())
  clinicId          String    @map("clinic_id")
  customerPackageId String    @map("customer_package_id")
  serviceId         String    @map("service_id")
  appointmentId     String?   @map("appointment_id")
  usedAt            DateTime? @map("used_at")

  customerPackage CustomerPackage @relation(fields: [customerPackageId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("customer_package_sessions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
// Append-only compliance record for critical actions (LGPD / security).
// Records who (userId) performed what (action) on which entity (entityId),
// from where (ip), and when (createdAt).

model AuditLog {
  id        String   @id @default(cuid())
  clinicId  String   @map("clinic_id")
  userId    String   @map("user_id")
  action    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, createdAt])
  @@map("audit_logs")
}

// ─── Accounts Payable ─────────────────────────────────────────────────────────
// Contas a pagar: despesas e compras com fornecedores.

model AccountsPayable {
  id              String                @id @default(uuid())
  clinicId        String                                     @map("clinic_id")
  description     String
  supplierName    String?                                    @map("supplier_name")
  category        String?
  amount          Int                                        // BRL cents
  dueDate         DateTime              @db.Date             @map("due_date")
  status          AccountsPayableStatus @default(PENDING)
  paidAt          DateTime?                                  @map("paid_at")
  paymentMethod   String?                                    @map("payment_method")
  notes           String?
  originType      String?                                    @map("origin_type")   // supply_purchase | manual
  originReference String?                                    @map("origin_reference") // ID da compra vinculada
  createdAt       DateTime              @default(now())      @map("created_at")
  updatedAt       DateTime              @updatedAt           @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Restrict)

  @@index([clinicId])
  @@index([clinicId, status])
  @@index([clinicId, dueDate])
  @@map("accounts_payable")
}

// ─── Manual Receipt ───────────────────────────────────────────────────────────
// Recebimento manual presencial com múltiplas formas de pagamento.

model ManualReceipt {
  id         String   @id @default(uuid())
  clinicId   String                       @map("clinic_id")
  billingId  String   @unique             @map("billing_id")
  totalPaid  Int                          @map("total_paid")  // BRL cents
  receivedAt DateTime @default(now())     @map("received_at")
  notes      String?
  createdAt  DateTime @default(now())     @map("created_at")

  clinic  Clinic             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  lines   ManualReceiptLine[]

  @@index([clinicId])
  @@map("manual_receipts")
}

model ManualReceiptLine {
  id              String  @id @default(uuid())
  manualReceiptId String                      @map("manual_receipt_id")
  clinicId        String                      @map("clinic_id")
  paymentMethod   String                      @map("payment_method")  // cash|pix|card|transfer|wallet_credit|wallet_voucher
  amount          Int                                                  // BRL cents
  walletEntryId   String?                     @map("wallet_entry_id")

  manualReceipt ManualReceipt @relation(fields: [manualReceiptId], references: [id], onDelete: Cascade)
  walletEntry   WalletEntry?  @relation(fields: [walletEntryId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([clinicId, walletEntryId])
  @@map("manual_receipt_lines")
}

// ─── Customer File ─────────────────────────────────────────────────────────────
// Arquivos enviados pelo upload flow (presign → R2 → confirm).
// Soft-delete via deletedAt — NUNCA hard-delete.

model CustomerFile {
  id                    String       @id @default(uuid())
  clinicId              String                                @map("clinic_id")
  customerId            String                                @map("customer_id")
  recordId              String?                               @map("record_id")    // FK → BodyMeasurementRecord (legado)
  measurementSessionId  String?                               @map("measurement_session_id") // FK → MeasurementSession (novo)
  name                  String
  mimeType              String                                @map("mime_type")
  size                  Int
  storageKey            String       @unique                  @map("storage_key")
  category              FileCategory
  status                FileUploadStatus @default(CONFIRMED)
  deletedAt             DateTime?                             @map("deleted_at")   // soft-delete — NUNCA Boolean deleted
  uploadedAt            DateTime     @default(now())          @map("uploaded_at")
  uploadedById          String                                @map("uploaded_by_id") // FK → User (rastreabilidade)

  clinic             Clinic                  @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer           Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  record             BodyMeasurementRecord?  @relation(fields: [recordId], references: [id], onDelete: SetNull)
  measurementSession MeasurementSession?     @relation(fields: [measurementSessionId], references: [id], onDelete: SetNull)

  @@index([clinicId, customerId])
  @@index([clinicId, recordId])
  @@index([clinicId, measurementSessionId])
  @@map("customer_files")
}

// ─── Body Measurement Field ───────────────────────────────────────────────────
// Campos configuráveis por clínica para registro de medidas corporais.

model BodyMeasurementField {
  id        String   @id @default(uuid())
  clinicId  String                          @map("clinic_id")
  name      String
  unit      String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())        @map("created_at")
  updatedAt DateTime @updatedAt             @map("updated_at")

  clinic Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  values BodyMeasurementValue[]

  @@index([clinicId, active])
  @@index([clinicId, order])
  @@map("body_measurement_fields")
}

// ─── Body Measurement Record ──────────────────────────────────────────────────
// Registro imutável de medidas corporais — sem PATCH após criação.

model BodyMeasurementRecord {
  id          String   @id @default(uuid())
  clinicId    String                          @map("clinic_id")
  customerId  String                          @map("customer_id")
  recordedAt  DateTime                        @map("recorded_at")   // permite retroativo
  notes       String?
  createdAt   DateTime @default(now())        @map("created_at")
  createdById String                          @map("created_by_id") // FK → User (rastreabilidade)

  clinic   Clinic                @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  values   BodyMeasurementValue[]
  files    CustomerFile[]

  @@index([clinicId, customerId, recordedAt])
  @@map("body_measurement_records")
}

// ─── Body Measurement Value ───────────────────────────────────────────────────
// Valor numérico de um campo de medição em um registro específico.

model BodyMeasurementValue {
  id       String  @id @default(uuid())
  clinicId String                          @map("clinic_id") // convenção global do schema
  recordId String                          @map("record_id")
  fieldId  String                          @map("field_id")
  value    Decimal @db.Decimal(10, 2)

  record BodyMeasurementRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  field  BodyMeasurementField  @relation(fields: [fieldId], references: [id], onDelete: Restrict)

  @@index([clinicId, recordId])
  @@map("body_measurement_values")
}

// ─── Measurement Sheets (novo modelo) ────────────────────────────────────────

// Ficha de Avaliação Corporal — configurável por clínica
model MeasurementSheet {
  id        String              @id @default(uuid())
  clinicId  String              @map("clinic_id")
  name      String
  type      MeasurementSheetType @default(SIMPLE)  // SIMPLE ou TABULAR
  active    Boolean             @default(true)
  order     Int                 @default(0)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt      @map("updated_at")

  clinic       Clinic                    @relation(fields: [clinicId], references: [id])
  fields       MeasurementField[]
  columns      MeasurementSheetColumn[]  // colunas da ficha TABULAR
  sheetRecords MeasurementSheetRecord[]

  @@unique([clinicId, name])
  @@index([clinicId, active, order])
  @@map("measurement_sheets")
}

// Coluna de ficha TABULAR — definida no nível da ficha (mesma para todas as linhas)
model MeasurementSheetColumn {
  id           String               @id @default(uuid())
  sheetId      String               @map("sheet_id")
  name         String
  inputType    MeasurementInputType @default(INPUT) @map("input_type")
  unit         String?              // opcional; usado quando inputType = INPUT e não isTextual
  isTextual    Boolean              @default(false) @map("is_textual")  // true: texto livre; false: numérico
  defaultValue String?              @map("default_value")              // valor pré-preenchido para campos textuais
  order        Int                  @default(0)

  sheet         MeasurementSheet         @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  tabularValues MeasurementTabularValue[]

  @@unique([sheetId, name])
  @@index([sheetId, order])
  @@map("measurement_sheet_columns")
}

// Campo/Linha de uma Ficha
// - Em fichas SIMPLE: inputType define se é teclado (INPUT) ou marcação (CHECK); unit para INPUT
// - Em fichas TABULAR: apenas name (colunas e inputType ficam em MeasurementSheetColumn)
// - subColumns: para campos que têm sub-divisões (ex: ["D","E"] para Direita/Esquerda)
model MeasurementField {
  id           String               @id @default(uuid())
  sheetId      String               @map("sheet_id")
  clinicId     String               @map("clinic_id")
  name         String
  inputType    MeasurementInputType @default(INPUT) @map("input_type")
  unit         String?              // usado em fichas SIMPLE com inputType INPUT e não isTextual
  isTextual    Boolean              @default(false) @map("is_textual")  // true: texto livre (fichas SIMPLE)
  defaultValue String?              @map("default_value")              // override do defaultValue da coluna para este campo
  subColumns   String[]             @default([])    @map("sub_columns")  // ex: ["D","E"] — sub-colunas por campo em fichas TABULAR
  order        Int                  @default(0)
  active       Boolean              @default(true)

  sheet         MeasurementSheet         @relation(fields: [sheetId], references: [id])
  values        MeasurementValue[]
  tabularValues MeasurementTabularValue[]

  @@unique([sheetId, name])
  @@index([sheetId, active, order])
  @@index([clinicId])
  @@map("measurement_fields")
}

// Sessão de Evolução — agrupa fichas preenchidas em uma data
model MeasurementSession {
  id          String   @id @default(uuid())
  clinicId    String   @map("clinic_id")
  customerId  String   @map("customer_id")
  recordedAt  DateTime @map("recorded_at")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")
  createdById String   @map("created_by_id")

  clinic       Clinic                   @relation(fields: [clinicId], references: [id])
  customer     Customer                 @relation(fields: [customerId], references: [id])
  createdBy    User                     @relation(fields: [createdById], references: [id])
  sheetRecords MeasurementSheetRecord[]
  files        CustomerFile[]

  @@index([clinicId, customerId, recordedAt])
  @@map("measurement_sessions")
}

// Registro de uma ficha dentro de uma sessão
model MeasurementSheetRecord {
  id        String @id @default(uuid())
  sessionId String @map("session_id")
  sheetId   String @map("sheet_id")

  session       MeasurementSession       @relation(fields: [sessionId], references: [id])
  sheet         MeasurementSheet         @relation(fields: [sheetId], references: [id])
  values        MeasurementValue[]
  tabularValues MeasurementTabularValue[]

  @@unique([sessionId, sheetId])
  @@map("measurement_sheet_records")
}

// Valor de campo SIMPLE — numérico (INPUT) ou booleano (CHECK) ou texto (INPUT + isTextual)
model MeasurementValue {
  id            String   @id @default(uuid())
  sheetRecordId String   @map("sheet_record_id")
  fieldId       String   @map("field_id")
  value         Decimal? @db.Decimal(10, 2)  // null quando inputType = CHECK ou isTextual = true
  checked       Boolean  @default(false)      // usado quando inputType = CHECK
  textValue     String?  @map("text_value")   // usado quando field.isTextual = true

  sheetRecord MeasurementSheetRecord @relation(fields: [sheetRecordId], references: [id])
  field       MeasurementField       @relation(fields: [fieldId], references: [id])

  @@unique([sheetRecordId, fieldId])
  @@map("measurement_values")
}

// Valor de célula TABULAR — cruzamento (linha=field, coluna=sheetColumn)
// subColumn: vazio para campos normais; "D"/"E" etc. para campos com field.subColumns
model MeasurementTabularValue {
  id            String   @id @default(uuid())
  sheetRecordId String   @map("sheet_record_id")
  fieldId       String   @map("field_id")
  sheetColumnId String   @map("sheet_column_id")
  subColumn     String   @default("") @map("sub_column")  // "" = sem sub-coluna; "D","E" etc.
  value         Decimal? @db.Decimal(10, 2)  // null quando coluna.inputType = CHECK ou isTextual = true
  checked       Boolean  @default(false)      // usado quando coluna.inputType = CHECK
  textValue     String?  @map("text_value")   // usado quando coluna.isTextual = true

  sheetRecord  MeasurementSheetRecord  @relation(fields: [sheetRecordId], references: [id])
  field        MeasurementField        @relation(fields: [fieldId], references: [id])
  sheetColumn  MeasurementSheetColumn  @relation(fields: [sheetColumnId], references: [id])

  @@unique([sheetRecordId, fieldId, sheetColumnId, subColumn])
  @@map("measurement_tabular_values")
}


// ─── Contract Template ─────────────────────────────────────────────────────────

model ContractTemplate {
  id          String    @id @default(uuid())
  clinicId    String    @map("clinic_id")
  name        String
  description String?
  storageKey  String?   @map("storage_key")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt      @map("updated_at")

  clinic    Clinic             @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  contracts CustomerContract[]

  @@index([clinicId])
  @@map("contract_templates")
}

// ─── Customer Contract ─────────────────────────────────────────────────────────

model CustomerContract {
  id            String         @id @default(uuid())
  clinicId      String         @map("clinic_id")
  customerId    String         @map("customer_id")
  templateId    String?        @map("template_id")   // null para uploads avulsos
  label         String?                               // nome exibido quando não há template
  status        ContractStatus @default(pending)
  signatureMode String?        @map("signature_mode")   // 'assinafy' | 'manual'
  externalId    String?        @map("external_id")       // ID no Assinafy
  signLink      String?        @map("sign_link")          // link de assinatura Assinafy
  signature     String?                                   // base64 assinatura manual
  signedPdfKey  String?        @map("signed_pdf_key")    // R2 key do PDF assinado
  signedAt      DateTime?      @map("signed_at")
  signerIp      String?        @map("signer_ip")
  sentAt        DateTime?      @map("sent_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt      @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  clinic    Clinic            @relation(fields: [clinicId], references: [id], onDelete: Restrict)
  customer  Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  template  ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([clinicId, customerId])
  @@map("customer_contracts")
}
