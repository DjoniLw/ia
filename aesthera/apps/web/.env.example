# ──────────────────────────────────────────────────────────────────────────────
# Aesthera Web — Environment Variables
# Copy this file to .env.local and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# URL of the Aesthera API backend
# Development: http://localhost:3000
# Production: https://api.aesthera.com.br (or your Railway API service URL)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Base domain for subdomain-based multi-tenant routing (optional).
# When set, the clinic slug is extracted from the subdomain:
#   clinica.aesthera.com.br → NEXT_PUBLIC_BASE_DOMAIN=aesthera.com.br → slug "clinica"
# When NOT set (e.g. flat Railway URL like web.up.railway.app), the slug is
# read from localStorage (saved automatically at login/register — no config needed).
# NEXT_PUBLIC_BASE_DOMAIN=aesthera.com.br
