# ──────────────────────────────────────────────────────────────────────────────
# Aesthera API — Environment Variables
# Copy this file to apps/api/.env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aesthera:aesthera@localhost:5433/aesthera_dev

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe (card payments) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── MercadoPago (PIX + boleto) ─────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Resend (email) ─────────────────────────────────────────────────────────────
# ⚠️  Required for email sending (verification emails, payment receipts, etc.)
# 1. Create a free account at https://resend.com
# 2. Generate an API key (Resend dashboard → API Keys → Create API Key)
# 3. Verify your sending domain under Resend → Domains (or use resend's sandbox for dev)
# 4. Set EMAIL_FROM to a verified address, e.g. noreply@yourdomain.com
# Without this key the API starts normally but all emails are silently dropped.
RESEND_API_KEY=
EMAIL_FROM=noreply@aesthera.com.br

# ── WhatsApp (Z-API) ───────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Google Gemini AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Optional: override the Gemini model used by the AI features.
# Switch this if you hit quota limits on the default model.
# Available models: gemini-2.0-flash (default), gemini-2.0-flash-lite, gemini-1.5-flash, etc.
GEMINI_MODEL=gemini-2.5-flash
