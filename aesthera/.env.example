# ──────────────────────────────────────────────────────────────────────────────
# Aesthera API — Environment Variables
# Copy this file to apps/api/.env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aesthera:aesthera@localhost:5433/aesthera_dev

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe (card payments) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── MercadoPago (PIX + boleto) ─────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── Resend (email) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@aesthera.com.br

# ── WhatsApp (Z-API) ───────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Google Gemini AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
