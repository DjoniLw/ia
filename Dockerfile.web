# Dockerfile.web — Aesthera Web (used by Railway)
# Build context = aesthera/apps/web  (Root Directory set in Railway service settings)
# For local Docker Compose use apps/web/Dockerfile instead.

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Paths are relative to the build context root (aesthera/apps/web/)
COPY package*.json ./
RUN npm ci

COPY . .

ARG NEXT_PUBLIC_API_URL=http://localhost:3000
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Optional: set to your custom root domain for subdomain-based tenant routing.
# e.g. --build-arg NEXT_PUBLIC_BASE_DOMAIN=aesthera.com.br
# Leave unset for flat-URL deployments (Railway, Vercel) — slug comes from localStorage.
ARG NEXT_PUBLIC_BASE_DOMAIN=""
ENV NEXT_PUBLIC_BASE_DOMAIN=${NEXT_PUBLIC_BASE_DOMAIN}

RUN npm run build

# ── Stage 2: run ──────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production

# Use Next.js standalone output (configured in next.config.mjs)
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3002

ENV PORT=3002
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
